{
  "rewrites": [
    {
      "source": "/api/nvidia/:match*",
      "destination": "https://integrate.api.nvidia.com/v1/:match*"
    },
    {
      "source": "/api/:match*",
      "destination": "https://roadmap-ai-server.onrender.com/api/:match*"
    },
    {
      "source": "/auth/:match*",
      "destination": "https://roadmap-ai-server.onrender.com/auth/:match*"
    },
    {
      "source": "/webhook/:match*",
      "destination": "https://roadmap-ai-server.onrender.com/webhook/:match*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
